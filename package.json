{
  "name": "nuts-and-bolts",
  "version": "0.1.3",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "release": "standard-version",
    "build:release": "npm run release && vite build",
    "preview": "vite preview",
    "test": "vitest --run src",
    "test:e2e": "playwright test",
    "check:accessibility": "node scripts/check_palettes.cjs",
    "test:watch": "vitest --watch",
    "simulate": "node scripts/run-sim.js",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint src --ext .ts,.tsx,.js,.jsx --fix"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "standard-version": "^9.5.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.2"
  },
  "vitest": {
    "environment": "jsdom",
    "include": [
      "src/**/*.test.*",
      "src/**/*.spec.*"
    ],
    "exclude": [
      "e2e/**"
    ]
  }
}
