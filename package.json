{
  "name": "nuts-and-bolts",
  "version": "0.2.11",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "release": "commit-and-tag-version",
    "build:release": "npm run release && vite build",
    "preview": "vite preview",
    "test": "vitest --run",
    "coverage": "vitest --run --coverage",
    "coverage:report": "vitest --run --coverage --reporter=default && node scripts/open-coverage.cjs",
    "test:e2e": "playwright test",
    "check:accessibility": "node scripts/check_palettes.cjs",
    "test:watch": "vitest --watch",
    "simulate": "node scripts/run-sim.js",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint src --ext .ts,.tsx,.js,.jsx --fix"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "vitest": {
    "environment": "jsdom",
    "include": [
      "tests/**/*.test.*",
      "tests/**/*.spec.*"
    ],
    "exclude": [
      "e2e/**"
    ],
    "coverage": {
      "exclude": [
        "src/assets/icons/**"
      ]
    }
  }
}
